PORT=5000
MONGO_URI=mongodb://localhost:27017/kiosk_pos
JWT_SECRET=change_me
JWT_REFRESH_SECRET=change_me_too

# Comma-separated list of origins allowed to make credentialed requests (CORS)
CORS_ORIGIN=http://localhost:5173

# Public URL of the deployed API, shown as a server option in Swagger docs (/api-docs)
SWAGGER_SERVER_URL=https://api.example.com

# Product image uploads go to Cloudinary when all three are set; otherwise
# they fall back to local disk storage under ./uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
