PORT=5000
MONGO_URI=mongodb://localhost:27017/kiosk_pos
JWT_SECRET=change_me
JWT_REFRESH_SECRET=change_me_too

# Comma-separated list of origins allowed to make credentialed requests (CORS)
CORS_ORIGIN=http://localhost:5173

# Public URL of the deployed API, shown as a server option in Swagger docs (/api-docs)
SWAGGER_SERVER_URL=https://api.example.com

# Product image uploads go to Cloudinary when all three are set; otherwise
# they fall back to local disk storage under ./uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Used to email signup OTPs via Resend. When unset, OTPs are logged to the
# console instead, so signup still works in local/dev environments.
RESEND_API_KEY=
RESEND_FROM=

# AI assistant (conversational product creation via /api/ai/chat)
# Business owners can supply their own Anthropic API key (Settings page),
# which is encrypted at rest using AI_KEY_ENCRYPTION_SECRET below. The shared
# ANTHROPIC_API_KEY is only used as a fallback for owners whose email is
# listed in OWNER_ALLOWED (comma-separated). Owners with neither are blocked
# from using the assistant.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
OWNER_ALLOWED=
AI_KEY_ENCRYPTION_SECRET=
